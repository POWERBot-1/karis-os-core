{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "INSURANCE_CLAIM_SETTLED",
  "description": "Event emitted when verified IoT sensor data triggers automatic parametric insurance claim approval and double-entry ledger settlement (`Rule 2, 5 & 6`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["INSURANCE_CLAIM_SETTLED"] },
    "event_category": { "type": "string", "enum": ["PAYMENT"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["PARAMETRIC_CROP_INSURANCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "claim_id": { "type": "string" },
        "policy_id": { "type": "string" },
        "insured_identity_id": { "type": "string" },
        "triggering_telemetry_id": { "type": "string" },
        "claim_amount_kes": { "type": "number", "minimum": 0 },
        "claim_status": { "type": "string" }
      },
      "required": ["claim_id", "policy_id", "insured_identity_id", "claim_amount_kes", "claim_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
