{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "COSMOX_MULTISIG_TREASURY_APPROVED",
  "description": "Event emitted when a high-value treasury request achieves full multi-signature RBAC sign-off per Rule 10.",
  "type": "object",
  "properties": {
    "request_id": { "type": "string" },
    "requester_account_id": { "type": "string" },
    "amount_krt": { "type": "number" },
    "purpose": { "type": "string" },
    "approvals_count": { "type": "integer" },
    "status": { "type": "string" },
    "ledger_entry_id": { "type": "string" }
  },
  "required": ["request_id", "requester_account_id", "amount_krt", "approvals_count", "status"]
}