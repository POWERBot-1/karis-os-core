{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HSM_NFC_TOKEN_GENERATED",
  "description": "Event emitted when the Hardware Security Module (`HSM`) generates an encrypted one-time NFC/QR payment cryptogram (`Section 41.4 & 38.4`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["HSM_NFC_TOKEN_GENERATED"] },
    "event_category": { "type": "string", "enum": ["PAYMENT"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["HARDWARE_SECURITY_MODULE_HSM_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "token_id": { "type": "string" },
        "nfc_cryptogram": { "type": "string" },
        "identity_id": { "type": "string" },
        "wallet_id": { "type": "string" },
        "authorized_amount_kes": { "type": "number", "exclusiveMinimum": 0 },
        "biometric_verification_method": { "type": "string" }
      },
      "required": ["token_id", "nfc_cryptogram", "identity_id", "wallet_id", "authorized_amount_kes", "biometric_verification_method"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
