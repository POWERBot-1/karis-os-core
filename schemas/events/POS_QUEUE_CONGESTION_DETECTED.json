{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POS_QUEUE_CONGESTION_DETECTED",
  "description": "Event emitted when the AI POS Queue Monitoring Engine detects queue bottlenecks and commands Express Lane activation.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["POS_QUEUE_CONGESTION_DETECTED"] },
    "event_category": { "type": "string", "enum": ["COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["AI_POS_QUEUE_SHRINKAGE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "log_id": { "type": "string" },
        "store_id": { "type": "string" },
        "terminal_id": { "type": "string" },
        "active_customers_in_line": { "type": "integer", "minimum": 0 },
        "estimated_wait_time_minutes": { "type": "number", "minimum": 0 },
        "congestion_status": { "type": "string" },
        "ai_recommendation_action": { "type": "string" }
      },
      "required": ["log_id", "store_id", "terminal_id", "active_customers_in_line", "congestion_status", "ai_recommendation_action"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
