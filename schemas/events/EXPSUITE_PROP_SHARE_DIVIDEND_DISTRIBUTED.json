{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EXPSUITE_PROP_SHARE_DIVIDEND_DISTRIBUTED",
  "description": "Event emitted when monthly property rental income dividend is distributed via exact double-entry ledger (`Rule 5 & Rule 9`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["EXPSUITE_PROP_SHARE_DIVIDEND_DISTRIBUTED"] },
    "event_category": { "type": "string", "enum": ["PROP_SHARE", "TREASURY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "syndication_id": { "type": "string" },
        "investor_identity_id": { "type": "string" },
        "dividend_amount_krt": { "type": "number", "minimum": 0 },
        "reference_transaction_id": { "type": "string" }
      },
      "required": ["syndication_id", "investor_identity_id", "dividend_amount_krt", "reference_transaction_id"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
