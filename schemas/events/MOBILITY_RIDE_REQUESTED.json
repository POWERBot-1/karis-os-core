{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MOBILITY_RIDE_REQUESTED",
  "description": "Event emitted when a passenger requests a ride or transport service in KARIS Mobility.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["MOBILITY_RIDE_REQUESTED"] },
    "event_category": { "type": "string", "enum": ["MOBILITY"] },
    "actor_identity_id": { "type": "string", "format": "uuid" },
    "organization_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "source_module": { "type": "string", "enum": ["MOBILITY_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "trip_id": { "type": "string", "format": "uuid" },
        "passenger_identity_id": { "type": "string", "format": "uuid" },
        "pickup_location_text": { "type": "string" },
        "dropoff_location_text": { "type": "string" },
        "estimated_distance_km": { "type": "number", "minimum": 0 },
        "total_fare_kes": { "type": "number", "minimum": 0 }
      },
      "required": ["trip_id", "passenger_identity_id", "pickup_location_text", "dropoff_location_text", "total_fare_kes"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
