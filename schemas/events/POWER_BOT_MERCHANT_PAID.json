{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POWER_BOT_MERCHANT_PAID",
  "description": "Event emitted when a user redeems or spends KRT prediction winnings at a KARIS OS merchant (`Eatery KDS`, `KARIS FARM`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["POWER_BOT_MERCHANT_PAID"] },
    "event_category": { "type": "string", "enum": ["POWER_BOT_X", "COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "merchant_organization_id": { "type": "string" },
        "amount_krt": { "type": "number", "minimum": 0 },
        "vertical_target": { "type": "string", "enum": ["KARIS_EATERY", "KARIS_FARM", "OMNICHANNEL_RETAIL", "FUTURE_INDUSTRIES"] },
        "order_reference": { "type": "string" }
      },
      "required": ["user_id", "merchant_organization_id", "amount_krt", "vertical_target"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
