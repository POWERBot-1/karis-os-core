{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "API_KEY_ISSUED_OR_REVOKED",
  "description": "Event emitted when the Administration Console issues, rotates, or revokes a cryptographic enterprise API key (`Section 38.4 & 43.2`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["API_KEY_ISSUED_OR_REVOKED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["OPERATIONAL_POLICY_AND_KEY_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "key_id": { "type": "string" },
        "key_prefix": { "type": "string" },
        "identity_id": { "type": "string" },
        "key_name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["key_id", "key_prefix", "identity_id", "key_name", "status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
