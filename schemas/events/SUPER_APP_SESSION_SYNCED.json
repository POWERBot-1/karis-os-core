{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SUPER_APP_SESSION_SYNCED",
  "description": "Event emitted when the Omnichannel Super App & Merchant Portal Gateway aggregates unified customer/merchant profiles across all 12 verticals.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["SUPER_APP_SESSION_SYNCED"] },
    "event_category": { "type": "string", "enum": ["IDENTITY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["OMNICHANNEL_PORTAL_GATEWAY_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "sync_id": { "type": "string" },
        "identity_id": { "type": "string" },
        "portal_type": { "type": "string", "enum": ["CUSTOMER_SUPER_APP", "MERCHANT_OMNICHANNEL_PORTAL"] },
        "active_verticals_count": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "enum": ["SYNCED_ACTIVE"] }
      },
      "required": ["sync_id", "identity_id", "portal_type", "active_verticals_count", "status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
