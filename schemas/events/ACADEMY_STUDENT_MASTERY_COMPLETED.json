{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACADEMY_STUDENT_MASTERY_COMPLETED",
  "description": "Event emitted when a student passes mastery evaluation (`>= 85% score`), recording immutable transcript and auto-minting KRT-EDU (`Rule 5, 7 & 9`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["ACADEMY_STUDENT_MASTERY_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["EDUCATION", "CURRENCY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "record_id": { "type": "string" },
        "student_identity_id": { "type": "string" },
        "institution_id": { "type": "string" },
        "concept_id": { "type": "string" },
        "mastery_score_pct": { "type": "number", "minimum": 0 },
        "krt_edu_reward_earned": { "type": "number", "minimum": 0 },
        "reference_transaction_id": { "type": "string" }
      },
      "required": ["record_id", "student_identity_id", "institution_id", "concept_id", "mastery_score_pct"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
