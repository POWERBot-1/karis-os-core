{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POS_CHECKOUT_COMPLETED",
  "description": "Event emitted when an omnichannel POS terminal completes an in-store checkout transaction.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["POS_CHECKOUT_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["COMMERCE"] },
    "actor_identity_id": { "type": "string", "format": "uuid" },
    "organization_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "source_module": { "type": "string", "enum": ["OMNICHANNEL_POS_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "session_id": { "type": "string", "format": "uuid" },
        "terminal_code": { "type": "string" },
        "store_id": { "type": "string", "format": "uuid" },
        "order_id": { "type": "string", "format": "uuid" },
        "total_kes_amount": { "type": "number", "minimum": 0 },
        "payment_method": { "type": "string" }
      },
      "required": ["session_id", "terminal_code", "store_id", "order_id", "total_kes_amount", "payment_method"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
