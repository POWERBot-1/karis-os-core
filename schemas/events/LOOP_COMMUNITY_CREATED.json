{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LOOP_COMMUNITY_CREATED",
  "description": "Event emitted when a public, private, regional, or educational community is created on Karis Loop (`Section 54`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["LOOP_COMMUNITY_CREATED"] },
    "event_category": { "type": "string", "enum": ["SOCIAL"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "community_id": { "type": "string" },
        "name": { "type": "string" },
        "community_type": { "type": "string" },
        "region_county": { "type": "string" },
        "creator_identity_id": { "type": "string" }
      },
      "required": ["community_id", "name", "community_type", "creator_identity_id"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
