{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KYC_VERIFICATION_COMPLETED",
  "description": "Event emitted when the Governance & Compliance Engine completes multi-tier KYC identification.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["KYC_VERIFICATION_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["GOVERNANCE_COMPLIANCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "kyc_id": { "type": "string" },
        "identity_id": { "type": "string" },
        "verification_tier": { "type": "string" },
        "kra_pin": { "type": "string" },
        "aml_sanction_check_status": { "type": "string" }
      },
      "required": ["kyc_id", "identity_id", "verification_tier", "aml_sanction_check_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
