{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ENERGY_SOLAR_UNIT_REGISTERED",
  "description": "Event emitted when a new PAYG solar home system, battery bank, or smart irrigation pump is registered in KARIS ENERGY.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["ENERGY_SOLAR_UNIT_REGISTERED"] },
    "event_category": { "type": "string", "enum": ["ENERGY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "installation_id": { "type": "string" },
        "owner_user_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "device_serial_number": { "type": "string" },
        "device_type": { "type": "string" },
        "rated_capacity_watts": { "type": "number", "minimum": 0 },
        "daily_token_rate_krt": { "type": "number", "minimum": 0 }
      },
      "required": ["installation_id", "owner_user_id", "device_serial_number", "device_type"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
