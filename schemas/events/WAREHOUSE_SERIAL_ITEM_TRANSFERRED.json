{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WAREHOUSE_SERIAL_ITEM_TRANSFERRED",
  "description": "Event emitted when an agricultural crate is logged via barcode serial tracking and transferred across multi-warehouse hubs (`Section 15.2`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["WAREHOUSE_SERIAL_ITEM_TRANSFERRED"] },
    "event_category": { "type": "string", "enum": ["COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["MULTI_WAREHOUSE_SERIAL_TRACKING_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "serial_item_id": { "type": "string" },
        "serial_barcode": { "type": "string" },
        "product_id": { "type": "string" },
        "warehouse_location_code": { "type": "string" },
        "item_status": { "type": "string" }
      },
      "required": ["serial_item_id", "serial_barcode", "product_id", "warehouse_location_code", "item_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
