{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WORKFLOW_STATE_CHANGED",
  "description": "Event emitted when a multi-step enterprise workflow transitions between states (Rule 10 human approval or AI auto-advance).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["WORKFLOW_STATE_CHANGED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["WORKFLOW_STATE_MACHINE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "instance_id": { "type": "string" },
        "workflow_code": { "type": "string" },
        "target_resource_id": { "type": "string" },
        "previous_state": { "type": "string" },
        "new_state": { "type": "string" },
        "approval_notes": { "type": "string" }
      },
      "required": ["instance_id", "workflow_code", "target_resource_id", "previous_state", "new_state"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
