{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POWER_BOT_DEPOSIT_COMPLETED",
  "description": "Event emitted when a user deposits KES via M-Pesa to convert to KRT inside Power BOT X.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["POWER_BOT_DEPOSIT_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["POWER_BOT_X", "PAYMENT"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "amount_kes": { "type": "number", "minimum": 0 },
        "mpesa_receipt_number": { "type": "string" },
        "converted_krt_amount": { "type": "number", "minimum": 0 },
        "wallet_id": { "type": "string" }
      },
      "required": ["user_id", "amount_kes", "converted_krt_amount", "wallet_id"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
