{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BORDERX_ACCOUNT_ONBOARDED",
  "description": "Event emitted when a regional trader receives their 9 multi-currency wallets per Rule 1 and Rule 6.",
  "type": "object",
  "properties": {
    "account_id": { "type": "string" },
    "identity_id": { "type": "string" },
    "account_number": { "type": "string" },
    "entity_type": { "type": "string" },
    "kes_wallet_id": { "type": "string" },
    "ugx_wallet_id": { "type": "string" },
    "tzs_wallet_id": { "type": "string" },
    "rwf_wallet_id": { "type": "string" },
    "bif_wallet_id": { "type": "string" },
    "ssp_wallet_id": { "type": "string" },
    "usd_wallet_id": { "type": "string" },
    "eur_wallet_id": { "type": "string" },
    "krt_wallet_id": { "type": "string" },
    "customs_account_ref": { "type": "string" }
  },
  "required": ["account_id", "identity_id", "krt_wallet_id", "customs_account_ref"]
}