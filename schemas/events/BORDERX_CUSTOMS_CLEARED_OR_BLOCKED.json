{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BORDERX_CUSTOMS_CLEARED_OR_BLOCKED",
  "description": "Event emitted when AI customs risk evaluation or human officer inspection clears or blocks cargo under Rule 10.",
  "type": "object",
  "properties": {
    "declaration_id": { "type": "string" },
    "trader_account_id": { "type": "string" },
    "customs_risk_score": { "type": "number" },
    "status": { "type": "string" },
    "officer_account_id": { "type": "string" },
    "audit_notes": { "type": "string" }
  },
  "required": ["declaration_id", "trader_account_id", "customs_risk_score", "status"]
}