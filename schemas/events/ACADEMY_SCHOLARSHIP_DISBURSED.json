{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACADEMY_SCHOLARSHIP_DISBURSED",
  "description": "Event emitted when an institutional scholarship stipend (`5,000 KRT`) is disbursed via Universal Double-Entry Ledger (`Rule 5 & Rule 9`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["ACADEMY_SCHOLARSHIP_DISBURSED"] },
    "event_category": { "type": "string", "enum": ["EDUCATION", "PAYMENT"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "disbursement_id": { "type": "string" },
        "institution_id": { "type": "string" },
        "student_identity_id": { "type": "string" },
        "amount_krt": { "type": "number", "minimum": 0 },
        "disbursement_type": { "type": "string" },
        "reference_transaction_id": { "type": "string" }
      },
      "required": ["disbursement_id", "institution_id", "student_identity_id", "amount_krt"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
