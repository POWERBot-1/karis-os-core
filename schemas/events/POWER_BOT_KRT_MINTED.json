{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POWER_BOT_KRT_MINTED",
  "description": "Event emitted when KRT tokens are minted for a Power BOT X deposit or promotional staking reward.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["POWER_BOT_KRT_MINTED"] },
    "event_category": { "type": "string", "enum": ["POWER_BOT_X", "CURRENCY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "amount_krt": { "type": "number", "minimum": 0 },
        "treasury_pool_id": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["user_id", "amount_krt", "treasury_pool_id", "reason"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
