{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRIVACY_CONSENT_UPDATED",
  "description": "Event emitted when a user grants or revokes granular privacy consent across marketing, EMR sharing, or AI scoring (`Section 38.7`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["PRIVACY_CONSENT_UPDATED"] },
    "event_category": { "type": "string", "enum": ["IDENTITY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["PRIVACY_CONSENT_AND_GDPR_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "consent_record_id": { "type": "string" },
        "identity_id": { "type": "string" },
        "consent_category": { "type": "string" },
        "is_granted": { "type": "boolean" }
      },
      "required": ["consent_record_id", "identity_id", "consent_category", "is_granted"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
