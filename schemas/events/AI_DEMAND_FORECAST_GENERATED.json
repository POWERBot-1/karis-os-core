{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI_DEMAND_FORECAST_GENERATED",
  "description": "Event emitted when the Enterprise Predictive Intelligence Engine forecasts SKU stockouts and reorder thresholds.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["AI_DEMAND_FORECAST_GENERATED"] },
    "event_category": { "type": "string", "enum": ["COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["PREDICTIVE_INTELLIGENCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "forecast_id": { "type": "string" },
        "product_id": { "type": "string" },
        "predicted_demand_units": { "type": "number", "minimum": 0 },
        "predicted_stockout_date": { "type": "string" },
        "recommended_reorder_units": { "type": "number", "minimum": 0 },
        "confidence_score_pct": { "type": "number" }
      },
      "required": ["forecast_id", "product_id", "predicted_demand_units", "recommended_reorder_units", "confidence_score_pct"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
