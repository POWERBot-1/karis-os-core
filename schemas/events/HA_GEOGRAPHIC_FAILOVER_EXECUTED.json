{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HA_GEOGRAPHIC_FAILOVER_EXECUTED",
  "description": "Event emitted when the Active-Active High Availability Engine executes geographic traffic failover across regional cluster nodes (`Section 40.8 & 45.3`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["HA_GEOGRAPHIC_FAILOVER_EXECUTED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["HA_GEOGRAPHIC_FAILOVER_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "failover_id": { "type": "string" },
        "failover_code": { "type": "string" },
        "failed_node_id": { "type": "string" },
        "promoted_node_id": { "type": "string" },
        "trigger_reason": { "type": "string" },
        "traffic_rerouted_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "ledger_continuity_status": { "type": "string" }
      },
      "required": ["failover_id", "failover_code", "failed_node_id", "promoted_node_id", "trigger_reason", "traffic_rerouted_pct"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
