{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CICD_QUALITY_GATE_EVALUATED",
  "description": "Event emitted when the CI/CD Automated Deployment Quality Gate Engine verifies release thresholds (`100% pytest pass rate`, `>1,500 ops/sec`, `Rule 9 clean`) (`Section 40.5 & 40.6`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["CICD_QUALITY_GATE_EVALUATED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["CICD_QUALITY_GATE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "evaluation_id": { "type": "string" },
        "pipeline_build_code": { "type": "string" },
        "pytest_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "stress_benchmark_ops_per_sec": { "type": "number", "minimum": 0 },
        "rule_9_audit_hash_chain_intact": { "type": "boolean" },
        "gate_decision": { "type": "string" }
      },
      "required": ["evaluation_id", "pipeline_build_code", "pytest_pass_rate_pct", "stress_benchmark_ops_per_sec", "rule_9_audit_hash_chain_intact", "gate_decision"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
