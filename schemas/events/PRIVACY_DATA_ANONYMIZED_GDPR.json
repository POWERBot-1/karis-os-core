{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRIVACY_DATA_ANONYMIZED_GDPR",
  "description": "Event emitted when personal identifiable information (PII) is anonymized under Kenya Data Protection Act / GDPR right-to-be-forgotten requests while preserving double-entry ledger SHA-256 hash chains (`Rule 9`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["PRIVACY_DATA_ANONYMIZED_GDPR"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["PRIVACY_CONSENT_AND_GDPR_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "anonymization_id": { "type": "string" },
        "original_identity_id": { "type": "string" },
        "anonymized_alias_code": { "type": "string" },
        "reason_code": { "type": "string" },
        "ledger_integrity_status": { "type": "string" }
      },
      "required": ["anonymization_id", "original_identity_id", "anonymized_alias_code", "reason_code", "ledger_integrity_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
