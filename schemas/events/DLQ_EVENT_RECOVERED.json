{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DLQ_EVENT_RECOVERED",
  "description": "Event emitted when the Distributed Dead-Letter Queue (DLQ) & Self-Healing Engine successfully retries and recovers a failed event dispatch.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["DLQ_EVENT_RECOVERED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["DLQ_SELF_HEALING_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "dispatch_id": { "type": "string" },
        "recovered_event_id": { "type": "string" },
        "consumer_name": { "type": "string" },
        "retry_count": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "enum": ["PROCESSED_RECOVERED"] }
      },
      "required": ["dispatch_id", "recovered_event_id", "consumer_name", "retry_count", "status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
