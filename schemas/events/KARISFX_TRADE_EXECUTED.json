{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KARISFX_TRADE_EXECUTED",
  "description": "Event emitted when a multi-asset trade is executed and settled via double-entry ledger per Rule 5 and Rule 9.",
  "type": "object",
  "properties": {
    "trade_id": { "type": "string" },
    "account_id": { "type": "string" },
    "asset_class": { "type": "string" },
    "symbol": { "type": "string" },
    "side": { "type": "string" },
    "requested_units": { "type": "number" },
    "execution_price": { "type": "number" },
    "total_value_usd": { "type": "number" },
    "final_fee_krt": { "type": "number" },
    "fee_discount_pct": { "type": "number" },
    "ledger_entry_id": { "type": "string" }
  },
  "required": ["trade_id", "account_id", "asset_class", "symbol", "final_fee_krt", "ledger_entry_id"]
}