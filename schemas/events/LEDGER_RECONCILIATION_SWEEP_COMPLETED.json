{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LEDGER_RECONCILIATION_SWEEP_COMPLETED",
  "description": "Event emitted when the Universal Double-Entry Ledger Reconciliation Engine sweeps wallets against transaction sums, issuing reversing adjustments (`Section 37.4 & 10.4`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["LEDGER_RECONCILIATION_SWEEP_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["TREASURY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["UNIVERSAL_LEDGER_RECONCILIATION_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "sweep_id": { "type": "string" },
        "sweep_code": { "type": "string" },
        "total_wallets_audited": { "type": "integer", "minimum": 0 },
        "total_ledger_entries_audited": { "type": "integer", "minimum": 0 },
        "discrepancies_detected_count": { "type": "integer", "minimum": 0 },
        "total_reversing_adjustments_kes": { "type": "number", "minimum": 0 },
        "reconciliation_status": { "type": "string" }
      },
      "required": ["sweep_id", "sweep_code", "total_wallets_audited", "total_ledger_entries_audited", "discrepancies_detected_count", "reconciliation_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
