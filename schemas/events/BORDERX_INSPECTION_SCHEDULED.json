{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BORDERX_INSPECTION_SCHEDULED",
  "description": "Event emitted when AI Customs Risk Engine flags suspicious patterns and mandates human customs officer physical inspection under Rule 10.",
  "type": "object",
  "properties": {
    "inspection_id": { "type": "string" },
    "declaration_id": { "type": "string" },
    "customs_officer_account_id": { "type": "string" },
    "border_post": { "type": "string" },
    "reason": { "type": "string" },
    "inspection_status": { "type": "string" }
  },
  "required": ["inspection_id", "declaration_id", "border_post", "reason", "inspection_status"]
}