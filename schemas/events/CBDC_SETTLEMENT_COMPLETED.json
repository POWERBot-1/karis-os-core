{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CBDC_SETTLEMENT_COMPLETED",
  "description": "Event emitted when the Central Bank Digital Currency (CBDC) Engine completes a wholesale or retail digital currency settlement.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["CBDC_SETTLEMENT_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["TREASURY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["CBDC_OPEN_BANKING_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "cbdc_tx_id": { "type": "string" },
        "central_bank_identifier": { "type": "string" },
        "sender_institution_id": { "type": "string" },
        "recipient_institution_id": { "type": "string" },
        "cbdc_asset_code": { "type": "string" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "settlement_type": { "type": "string" },
        "cryptographic_signature": { "type": "string" }
      },
      "required": ["cbdc_tx_id", "central_bank_identifier", "sender_institution_id", "recipient_institution_id", "amount", "settlement_type"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
