{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FRAUD_ANOMALY_DETECTED",
  "description": "Event emitted when the AI Fraud Detection & Velocity Anomaly Engine detects impossible travel, structuring, or brute-force velocity.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["FRAUD_ANOMALY_DETECTED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["AI_FRAUD_VELOCITY_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "velocity_id": { "type": "string" },
        "identity_id": { "type": "string" },
        "amount_kes": { "type": "number", "minimum": 0 },
        "device_fingerprint": { "type": "string" },
        "location_gps": { "type": "string" },
        "fraud_risk_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "flagged_anomaly_type": { "type": "string" },
        "action_taken": { "type": "string" }
      },
      "required": ["velocity_id", "identity_id", "amount_kes", "fraud_risk_score", "flagged_anomaly_type", "action_taken"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
