{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "REAL_ESTATE_SYNDICATION_ALLOCATED",
  "description": "Event emitted when a retail investor acquires fractional property syndication units in KARIS Prop-Share.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["REAL_ESTATE_SYNDICATION_ALLOCATED"] },
    "event_category": { "type": "string", "enum": ["TREASURY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["FUTURE_INDUSTRIES_REAL_ESTATE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "syndication_id": { "type": "string" },
        "property_code": { "type": "string" },
        "investor_identity_id": { "type": "string" },
        "units_purchased": { "type": "number", "exclusiveMinimum": 0 },
        "total_amount_kes": { "type": "number", "exclusiveMinimum": 0 },
        "expected_rental_yield_pct": { "type": "number" }
      },
      "required": ["syndication_id", "property_code", "investor_identity_id", "units_purchased", "total_amount_kes"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
