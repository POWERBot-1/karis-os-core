{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "REGULATORY_COMPLIANCE_REPORT_FILED",
  "description": "Event emitted when the Automated Regulatory Compliance Engine compiles verifiable multi-jurisdictional inspection reports (`Section 35.4 & 38.8`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["REGULATORY_COMPLIANCE_REPORT_FILED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["AUTOMATED_REGULATORY_COMPLIANCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "report_id": { "type": "string" },
        "report_code": { "type": "string" },
        "jurisdiction_code": { "type": "string" },
        "report_type": { "type": "string" },
        "total_records_audited": { "type": "integer", "minimum": 0 },
        "compliance_status": { "type": "string" }
      },
      "required": ["report_id", "report_code", "jurisdiction_code", "report_type", "total_records_audited", "compliance_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
