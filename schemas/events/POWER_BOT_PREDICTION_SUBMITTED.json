{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POWER_BOT_PREDICTION_SUBMITTED",
  "description": "Event emitted when a user submits a prediction entry, escrowing KRT via UniversalLedgerEngine.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["POWER_BOT_PREDICTION_SUBMITTED"] },
    "event_category": { "type": "string", "enum": ["POWER_BOT_X", "PREDICTION"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "prediction_id": { "type": "string" },
        "user_id": { "type": "string" },
        "fixture_id": { "type": "string" },
        "predicted_outcome": { "type": "string" },
        "stake_krt": { "type": "number", "minimum": 0 },
        "potential_payout_krt": { "type": "number", "minimum": 0 },
        "league_id": { "type": "string" }
      },
      "required": ["prediction_id", "user_id", "fixture_id", "predicted_outcome", "stake_krt"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
