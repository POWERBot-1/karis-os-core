{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EDUCATION_TUITION_INSTALLMENT_PAID",
  "description": "Event emitted when a parent/guardian pays a student tuition fee installment via KARIS Edu-Pay, unlocking KRT-EDU scholarship bonuses.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["EDUCATION_TUITION_INSTALLMENT_PAID"] },
    "event_category": { "type": "string", "enum": ["COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["FUTURE_INDUSTRIES_EDUCATION_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "plan_id": { "type": "string" },
        "student_identity_id": { "type": "string" },
        "institution_name": { "type": "string" },
        "amount_paid_kes": { "type": "number", "exclusiveMinimum": 0 },
        "krt_edu_tokens_awarded": { "type": "number", "minimum": 0 },
        "status": { "type": "string" }
      },
      "required": ["plan_id", "student_identity_id", "institution_name", "amount_paid_kes", "krt_edu_tokens_awarded", "status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
