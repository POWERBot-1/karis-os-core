{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LOOP_SHOPPABLE_CHECKOUT_COMPLETED",
  "description": "Event emitted when a consumer completes a shoppable product purchase (`SKU-AVO-01`, `SOLAR-01`) directly from a Karis Loop post (`One Wallet Economy`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["LOOP_SHOPPABLE_CHECKOUT_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["SOCIAL", "COMMERCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "buyer_identity_id": { "type": "string" },
        "linked_product_id": { "type": "string" },
        "merchant_organization_id": { "type": "string" },
        "amount_kes_or_krt": { "type": "number", "minimum": 0 },
        "payment_method": { "type": "string" }
      },
      "required": ["post_id", "buyer_identity_id", "linked_product_id", "amount_kes_or_krt"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
