{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CHAOS_RESILIENCE_DRILL_COMPLETED",
  "description": "Event emitted when the Chaos Engineering & Fault Injection Engine completes simulated network/database outage resilience drills (`Section 44.2`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["CHAOS_RESILIENCE_DRILL_COMPLETED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["CHAOS_RESILIENCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "drill_id": { "type": "string" },
        "drill_code": { "type": "string" },
        "fault_type": { "type": "string" },
        "target_component": { "type": "string" },
        "dlq_events_recovered_count": { "type": "integer", "minimum": 0 },
        "drill_status": { "type": "string" }
      },
      "required": ["drill_id", "drill_code", "fault_type", "target_component", "drill_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
