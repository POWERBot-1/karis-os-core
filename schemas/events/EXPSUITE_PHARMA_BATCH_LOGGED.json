{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EXPSUITE_PHARMA_BATCH_LOGGED",
  "description": "Event emitted when a temperature-sensitive pharmaceutical batch is logged in KARIS PHARMA-TRACE.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "enum": ["EXPSUITE_PHARMA_BATCH_LOGGED"] },
    "event_category": { "type": "string", "enum": ["PHARMA"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "batch_id": { "type": "string" },
        "product_id": { "type": "string" },
        "batch_number": { "type": "string" },
        "qr_traceability_code": { "type": "string" },
        "storage_min_celsius": { "type": "number" },
        "storage_max_celsius": { "type": "number" }
      },
      "required": ["batch_id", "product_id", "batch_number", "qr_traceability_code"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "timestamp", "payload"]
}
