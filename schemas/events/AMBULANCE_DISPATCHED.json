{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AMBULANCE_DISPATCHED",
  "description": "Event emitted when the AI Emergency Medical Ambulance Dispatching Engine matches and dispatches the nearest life-support ambulance.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["AMBULANCE_DISPATCHED"] },
    "event_category": { "type": "string", "enum": ["HEALTHCARE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["AI_EMERGENCY_AMBULANCE_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "emergency_id": { "type": "string" },
        "ambulance_id": { "type": "string" },
        "unit_code": { "type": "string" },
        "life_support_tier": { "type": "string" },
        "pickup_gps": { "type": "string" },
        "estimated_arrival_minutes": { "type": "number", "minimum": 0 }
      },
      "required": ["emergency_id", "ambulance_id", "unit_code", "life_support_tier", "pickup_gps", "estimated_arrival_minutes"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
