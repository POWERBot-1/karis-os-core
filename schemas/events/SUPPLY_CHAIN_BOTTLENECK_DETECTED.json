{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SUPPLY_CHAIN_BOTTLENECK_DETECTED",
  "description": "Event emitted when the AI Supply Chain Bottleneck Analyzer detects corridor backlogs and calculates dynamic bypass routes (`Section 27.4 & 13.4`).",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["SUPPLY_CHAIN_BOTTLENECK_DETECTED"] },
    "event_category": { "type": "string", "enum": ["DELIVERY"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["AI_SUPPLY_CHAIN_BOTTLENECK_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "bottleneck_id": { "type": "string" },
        "corridor_code": { "type": "string" },
        "transit_delay_hours": { "type": "number", "minimum": 0 },
        "backlogged_crates": { "type": "integer", "minimum": 0 },
        "recommended_bypass_action": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["bottleneck_id", "corridor_code", "transit_delay_hours", "backlogged_crates", "recommended_bypass_action", "status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
