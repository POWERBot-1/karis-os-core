{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TICKET_ESCALATED",
  "description": "Event emitted when the Call Center SLA Management Engine flags SLA breaches and auto-escalates support tickets to senior supervisors.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string", "enum": ["TICKET_ESCALATED"] },
    "event_category": { "type": "string", "enum": ["GOVERNANCE"] },
    "actor_identity_id": { "type": "string" },
    "organization_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "source_module": { "type": "string", "enum": ["CALL_CENTER_SLA_ENGINE"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "properties": {
        "escalation_id": { "type": "string" },
        "ticket_id": { "type": "string" },
        "previous_agent_id": { "type": "string" },
        "escalated_to_supervisor_id": { "type": "string" },
        "escalation_reason": { "type": "string" },
        "sla_status": { "type": "string" }
      },
      "required": ["escalation_id", "ticket_id", "escalated_to_supervisor_id", "escalation_reason", "sla_status"]
    }
  },
  "required": ["event_id", "event_type", "event_category", "actor_identity_id", "organization_id", "correlation_id", "source_module", "timestamp", "payload"]
}
